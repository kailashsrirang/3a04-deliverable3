        +displayMessage() : void
    }

    class RBACController <<Control>> {
        +viewRoles() : JSON
        +updateRole(PersonID, NewRole) : boolean
        -authenticate() : boolean
        +logEvent() : boolean
        +verifyRole() : boolean
    }

    class RBACModel <<Abstraction>> {
