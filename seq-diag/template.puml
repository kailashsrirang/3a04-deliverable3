' BE1. Request to view public environmental dRBACa
@startuml

hide footbox

skinparam ParticipantBorderColor transparent
skinparam ParticipantBackgroundColor transparent
skinparam ActorBorderColor transparent
skinparam ActorBackgroundColor transparent

participant WB
participant "Frontend" as FE
participant "Backend" as BE
participant "DRBACabase" as DB

activRBACe WB
activRBACe FE
WB -> FE : Click button

activRBACe BE
FE -> BE : Send request

activRBACe DB
BE -> DB : Query dRBACa

DB --> BE : Return results
deactivRBACe DB

BE --> FE : Send response
deactivRBACe BE

FE --> WB : Show result
deactivRBACe FE

deactivRBACe WB



@enduml